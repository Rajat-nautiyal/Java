    public int findContentChildren(int[] g, int[] s) {
        int n = g.length;
        int m = s.length;
        Arrays.sort(g);
        Arrays.sort(s);
        int[][] dp = new int[n+1][m+1];

        for(int i = n-1; i >= 0; i--){
            for(int j = m-1; j >= 0; j--){
                int skip = dp[i][j+1];
                int take = 0;
                if(s[j] >= g[i]){
                    take = 1 + dp[i+1][j+1];
                }
                dp[i][j] = Math.max(skip, take);
            }
        }
        return dp[0][0];
    }

//Space Opt
    public int findContentChildren(int[] g, int[] s) {
        int n = g.length;
        int m = s.length;
        Arrays.sort(g);
        Arrays.sort(s);
        int[] next = new int[m+1];
        int prev = 0;
        for(int i = n-1; i >= 0; i--){
            int[] curr = new int[m+1];
            prev = 0;
            for(int j = m-1; j >= 0; j--){
                int skip = prev;
                int take = 0;
                if(s[j] >= g[i]){
                    take = 1 + next[j+1];
                }
                curr[j] = Math.max(skip, take);
                prev = curr[j];
            }
            next = curr;
        }
        return next[0];
    }
