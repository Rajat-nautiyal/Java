class Solution {
    public int helper(int gi, int si, int[] g, int[] s, int[][] dp){
        if(gi >= g.length || si >= s.length){
            return 0;
        }
        int res = 0;
        if(dp[gi][si] != -1) return dp[gi][si];
        //case1 :- greed is satisfied,so move both ind
        if(s[si] >= g[gi]){
            res = helper(gi+1, si+1, g, s, dp)+1;
        }
        //case2 :-  greed is not satisfied
        res = Math.max(res, helper(gi, si+1, g, s, dp));
        dp[gi][si] = res;
        return res;
    }
    public int findContentChildren(int[] g, int[] s) {
        int[][] dp = new int[g.length+1][s.length+1];
        Arrays.sort(g);
        Arrays.sort(s);
        for(int i = 0; i < g.length; i++){
            Arrays.fill(dp[i], -1);
        }
        return helper(0, 0, g, s, dp);
    }
}
