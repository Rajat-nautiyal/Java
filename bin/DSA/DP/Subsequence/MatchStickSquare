473. Matchsticks to Square

//Very Similar to 698. Partition to K Equal Sum Subsets
class Solution {
    public boolean backtrack(int ind, int currSum, int sides, int tar, int[] arr, boolean[] vis){
        if (sides == 0) return true;    
        if(currSum == tar) return backtrack(0, 0, sides-1, tar, arr, vis);
        
        for(int i = ind; i < arr.length; i++){
            if(!vis[i] && currSum + arr[i] <= tar){
                vis[i] = true;
                if(backtrack(i+1, currSum + arr[i], sides, tar, arr, vis)){
                    return true;
                }
                vis[i] = false;
                if(currSum == 0) return false;
            }
        }
        return false;
    }
    public boolean makesquare(int[] matchsticks) {
        int totsum = 0;
        int n = matchsticks.length;
        for(int v : matchsticks){
            totsum += v;
        }
        if((totsum % 4) != 0) return false;
        int tar = totsum / 4;
        boolean[] vis = new boolean[n];
        Arrays.sort(matchsticks); // without sorting it will still pass
        Collections.reverse(Arrays.asList(matchsticks));
        return backtrack(0, 0, 4, tar, matchsticks, vis);
    }
}